generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  passwordHash  String
  program       String         @default("")
  year          Int            @default(0)
  courses       String[]
  createdAt     DateTime       @default(now())
  owned         StudySession[] @relation("Owner")
  joined        StudySession[] @relation("Participants")
  messages      Message[]
  notifications Notification[]
}

model Message {
  id        String       @id @default(uuid())
  content   String
  sessionId String
  session   StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  authorId  String
  author    User         @relation(fields: [authorId], references: [id])
  createdAt DateTime     @default(now())
}

model StudySession {
  id            String         @id @default(uuid())
  courseCode    String
  topics        String[]
  description   String
  ownerId       String
  owner         User           @relation("Owner", fields: [ownerId], references: [id])
  participants  User[]         @relation("Participants")
  startTime     DateTime
  endTime       DateTime
  endedEarly      Boolean        @default(false)
  maxParticipants Int?
  locationType    String
  location      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  messages      Message[]
  notifications Notification[]
}

model Notification {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId     String
  session       StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type          String       @default("session_ended")
  attendeeCount Int?
  requesterId   String?
  requestStatus String       @default("resolved")
  read          Boolean      @default(false)
  createdAt     DateTime     @default(now())
}
